# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
NETWORK_CLIENT_URL=http://192.168.1.X:5173
NETWORK_HOST=192.168.1.X

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nmn_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_here_min_64_chars
JWT_EXPIRES_IN=7d

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Admin Default Credentials (Change after first login)
DEFAULT_ADMIN_EMAIL=admin@nmn.org
DEFAULT_ADMIN_PASSWORD=Admin@123

# ─── Khalti Payment Gateway ───────────────────────────────────────────────────
# Get keys from: https://khalti.com/developer/
KHALTI_SECRET_KEY=your_khalti_secret_key_here
# For testing use: test_secret_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── eSewa Payment Gateway ───────────────────────────────────────────────────
# Get credentials from: https://esewa.com.np/epay/main
# Test product code: EPAYTEST  |  Live: your registered product code
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_VERIFY_URL=https://rc.esewa.com.np/api/epay/transaction/status/
# For production:
# ESEWA_URL=https://epay.esewa.com.np/api/epay/main/v2/form
# ESEWA_VERIFY_URL=https://epay.esewa.com.np/api/epay/transaction/status/

